
const OBJECTIVE_QUESTIONS = Array.from({ length: 14 }, (_, index) => index + 1)
const SUBJECTIVE_QUESTIONS = Array.from({ length: 11 }, (_, index) => index + 1)
const OBJECTIVE_CHOICES = [1, 2, 3, 4, 5]
const EXAM_DURATION_MINUTES = 100

type Step = 'tutorial' | 'marking' | 'result'
type AnswerType = 'objective' | 'subjective'
type GradeResult = 'correct' | 'wrong' | 'unanswered' | 'duplicated'

type ExamSummary = {
  title: string
  description: string
  supervisorName: string
  totalQuestions: number
  totalScore: number
}

type StudentForm = {
  name: string
  school: string
  grade: string
  studentNumber: string
  seatNumber: string
}

type SubmitPayload = {
  name: string
  school: string
  grade: number
  studentNumber: number
  seatNumber: number
  answers: Array<{
    answerType: AnswerType
    number: number
    answer: number
  }>
}

type SubmitResponse = {
  title: string
  score: number
  correctCount: number
  wrongCount: number
  unansweredCount: number
  results: Array<{
    answerType: AnswerType
    number: number
    result: GradeResult
  }>
}

const resultLabelMap: Record<GradeResult, string> = {
  correct: '?•лӢө',
  wrong: '?ӨлӢө',
  unanswered: 'лҜёмқ‘??,
  duplicated: 'мӨ‘ліө ?ңм¶ң',
}

const resultToneMap: Record<GradeResult, string> = {
  correct: 'border-emerald-200 bg-emerald-50 text-emerald-700',
  wrong: 'border-rose-200 bg-rose-50 text-rose-700',
  unanswered: 'border-stone-200 bg-stone-100 text-stone-600',
  duplicated: 'border-amber-200 bg-amber-50 text-amber-700',
}

async function fetchExamSummary() {
  const response = await fetch('/api/exams')

  if (!response.ok) {
    throw new Error('?ңн—ҳ ?•ліҙлҘ?л¶Ҳлҹ¬?Өм? лӘ»н–Ҳ?өлӢҲ??')
  }

  const payload = (await response.json()) as {
    data: ExamSummary
  }

  return payload.data
}

async function submitExam(payload: SubmitPayload) {
  const response = await fetch('/api/exams/submit', {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
    },
    body: JSON.stringify(payload),
  })

  if (!response.ok) {
    throw new Error('?өм•Ҳ ?ңм¶ң???ӨнҢЁ?ҲмҠө?ҲлӢӨ.')
  }

  const data = (await response.json()) as {
    data: SubmitResponse
  }

  return data.data
}

function formatTime(totalSeconds: number) {
  const minutes = Math.floor(totalSeconds / 60)
  const seconds = totalSeconds % 60

  return `${String(minutes).padStart(2, '0')}:${String(seconds).padStart(2, '0')}`
}

function buildSubmitPayload(
  studentForm: StudentForm,
  objectiveAnswers: Record<number, number | null>,
  subjectiveAnswers: Record<number, string>,
) {
  const answers: SubmitPayload['answers'] = []

  for (const number of OBJECTIVE_QUESTIONS) {
    const answer = objectiveAnswers[number]

    if (answer != null) {
      answers.push({
        answerType: 'objective',
        number,
        answer,
      })
    }
  }

  for (const number of SUBJECTIVE_QUESTIONS) {
    const rawValue = subjectiveAnswers[number]?.trim()

    if (rawValue) {
      answers.push({
        answerType: 'subjective',
        number,
        answer: Number(rawValue),
      })
    }
  }

  return {
    name: studentForm.name.trim(),
    school: studentForm.school.trim(),
    grade: Number(studentForm.grade),
    studentNumber: Number(studentForm.studentNumber),
    seatNumber: Number(studentForm.seatNumber),
    answers,
  }
}

function resultCount(results: SubmitResponse['results'], answerType: AnswerType, result: GradeResult) {
  return results.filter((entry) => entry.answerType === answerType && entry.result === result).length
}

function App() {
  const { data, isLoading, isError, error } = useQuery({
    queryKey: ['exam-summary'],
    queryFn: fetchExamSummary,
  })
  const [step, setStep] = useState<Step>('tutorial')
  const [remainingSeconds, setRemainingSeconds] = useState(EXAM_DURATION_MINUTES * 60)
  const [validationMessage, setValidationMessage] = useState('')
  const [studentForm, setStudentForm] = useState<StudentForm>({
    name: '',
    school: '',
    grade: '1',
    studentNumber: '',
    seatNumber: '',
  })
  const [objectiveAnswers, setObjectiveAnswers] = useState<Record<number, number | null>>(
    () => Object.fromEntries(OBJECTIVE_QUESTIONS.map((number) => [number, null])) as Record<number, number | null>,
  )
  const [subjectiveAnswers, setSubjectiveAnswers] = useState<Record<number, string>>(
    () => Object.fromEntries(SUBJECTIVE_QUESTIONS.map((number) => [number, ''])) as Record<number, string>,
  )

  const submitMutation = useMutation({
    mutationFn: submitExam,
    onSuccess: () => {
      setStep('result')
      setValidationMessage('')
    },
  })

  useEffect(() => {
    if (step !== 'marking') {
      return undefined
    }

    const timer = window.setInterval(() => {
      setRemainingSeconds((current) => {
        if (current <= 1) {
          window.clearInterval(timer)
          return 0
        }

        return current - 1
      })
    }, 1000)

    return () => {
      window.clearInterval(timer)
    }
  }, [step])

  const objectiveAnsweredCount = Object.values(objectiveAnswers).filter((value) => value != null).length
  const subjectiveAnsweredCount = Object.values(subjectiveAnswers).filter((value) => value.trim() !== '').length
  const totalAnsweredCount = objectiveAnsweredCount + subjectiveAnsweredCount

  const handleStartExam = () => {
    setStep('marking')
    setRemainingSeconds(EXAM_DURATION_MINUTES * 60)
    setValidationMessage('')
  }

  const handleObjectiveSelect = (questionNumber: number, choice: number) => {
    setObjectiveAnswers((current) => ({
      ...current,
      [questionNumber]: current[questionNumber] === choice ? null : choice,
    }))
  }

  const handleStudentFieldChange = (field: keyof StudentForm, value: string) => {
    setStudentForm((current) => ({
      ...current,
      [field]: value,
    }))
  }

  const handleSubmit = () => {
    const payload = buildSubmitPayload(studentForm, objectiveAnswers, subjectiveAnswers)

    if (!payload.name || !payload.school) {
      setValidationMessage('?ҙлҰ„кі??ҷкөҗлӘ…мқ„ лЁјм? ?…л Ҙ??мЈјм„ё??')
      return
    }

    if (!Number.isInteger(payload.grade) || payload.grade <= 0) {
      setValidationMessage('?ҷл…„?Җ 1 ?ҙмғҒ???«мһҗлЎ??…л Ҙ??мЈјм„ё??')
      return
    }

    if (!Number.isInteger(payload.studentNumber) || payload.studentNumber <= 0) {
      setValidationMessage('?ҷмғқ лІҲнҳё??1 ?ҙмғҒ???«мһҗлЎ??…л Ҙ??мЈјм„ё??')
      return
    }

    if (!Number.isInteger(payload.seatNumber) || payload.seatNumber <= 0) {
      setValidationMessage('мўҢм„қ лІҲнҳё??1 ?ҙмғҒ???«мһҗлЎ??…л Ҙ??мЈјм„ё??')
      return
    }

    const invalidSubjectiveAnswer = payload.answers.some(
      (answer) => answer.answerType === 'subjective' && Number.isNaN(answer.answer),
    )

    if (invalidSubjectiveAnswer) {
      setValidationMessage('мЈјк????өм•Ҳ?Җ ?«мһҗл§??…л Ҙ??мЈјм„ё??')
      return
    }

    setValidationMessage('')
    submitMutation.mutate(payload)
  }

  const result = submitMutation.data

  return (
    <main className="min-h-screen bg-[radial-gradient(circle_at_top,#fff5dd_0%,#f6ead2_34%,#ead9bc_100%)] px-4 py-6 text-stone-900 sm:px-6 lg:px-10">
      <div className="mx-auto flex min-h-[calc(100vh-3rem)] max-w-7xl flex-col gap-6 rounded-[2rem] border border-black/10 bg-white/75 p-5 shadow-[0_30px_90px_rgba(86,54,14,0.14)] backdrop-blur sm:p-8 lg:grid lg:grid-cols-[1.35fr_0.9fr] lg:items-stretch lg:gap-8">
        <section className="flex flex-col justify-between rounded-[1.5rem] bg-[#1f4a3d] p-6 text-stone-50 sm:p-8">
          <div className="space-y-6">
            <div className="inline-flex w-fit items-center gap-2 rounded-full border border-white/15 bg-white/10 px-4 py-2 text-sm font-medium tracking-[0.14em] text-amber-100 uppercase">
              Base Mock Exam
            </div>

            <div className="space-y-4">
              <p className="max-w-xl text-sm leading-6 text-amber-50/80 sm:text-base">
                ?°м№ҳ?ӨнҒ¬лҰ?кё°л°ҳ лӘЁмқҳкі мӮ¬ ?ҳкІҪ??к°Җ?•н•ҙ ?ңнҶ лҰ¬м–ј, OMR л§ҲнӮ№, мұ„м җ кІ°кіј ?•мқё ?җлҰ„к№Ңм? ???”л©ҙ ?Ҳм—җ??лЁјм? кІҖмҰқн•  ???ҲкІҢ кө¬м„ұ?ҲмҠө?ҲлӢӨ.
              </p>
              <h1 className="max-w-3xl font-serif text-4xl leading-tight tracking-[-0.04em] sm:text-5xl lg:text-6xl">
                {step === 'result'
                  ? 'мұ„м җ кІ°кіјлҘ??•мқё?ҳм„ё??'
                  : isLoading
                    ? '?ңн—ҳ ?•ліҙлҘ?л¶Ҳлҹ¬?ӨлҠ” мӨ‘мһ…?ҲлӢӨ.'
                    : data?.title ?? 'лӘЁмқҳкі мӮ¬ ?‘мӢң мӨҖл№?}
              </h1>
              <p className="max-w-2xl text-base leading-7 text-amber-50/85 sm:text-lg">
                {isError
                  ? error instanceof Error
                    ? error.message
                    : '?????ҶлҠ” ?ӨлҘҳк°Җ л°ңмғқ?ҲмҠө?ҲлӢӨ.'
                  : step === 'tutorial'
                    ? '?ңн—ҳ ???ҲлӮҙлҘ??•мқё?ҳкі  ?‘мӢңлҘ??ңмһ‘?ҳм„ё?? ?ңмһ‘ ?„м—җ???Ём? ?ңк°„кі??Ёк»ҳ к°қк??? мЈјк????өм•Ҳ???…л Ҙ?????ҲмҠө?ҲлӢӨ.'
                    : step === 'marking'
                      ? '?ҷмғқ ?•ліҙлҘ??…л Ҙ?ҳкі  OMR м№ҙл“ң???өмқ„ л§ҲнӮ№?????ңм¶ң?ҳм„ё??'
                      : '?ңм¶ң???қлӮ¬?өлӢҲ?? л¬ён•ӯлі?кІ°кіј?Җ ?„мІҙ ?җмҲҳлҘ?л°”лЎң ?•мқё?????ҲмҠө?ҲлӢӨ.'}
              </p>
            </div>
          </div>

          <div className="mt-8 grid gap-4 sm:grid-cols-3">
            <article className="rounded-[1.25rem] border border-white/10 bg-white/8 p-4">
              <p className="text-xs uppercase tracking-[0.18em] text-amber-100/75">к°җлҸ…кҙҖ</p>
              <p className="mt-2 text-2xl font-semibold">{data?.supervisorName ?? '-'}</p>
            </article>
            <article className="rounded-[1.25rem] border border-white/10 bg-white/8 p-4">
              <p className="text-xs uppercase tracking-[0.18em] text-amber-100/75">л¬ён•ӯ ??/p>
              <p className="mt-2 text-2xl font-semibold">{data?.totalQuestions ?? '-'}л¬ён•ӯ</p>
            </article>
            <article className="rounded-[1.25rem] border border-white/10 bg-white/8 p-4">
              <p className="text-xs uppercase tracking-[0.18em] text-amber-100/75">мҙқм җ</p>
              <p className="mt-2 text-2xl font-semibold">{data?.totalScore ?? '-'}??/p>
            </article>
          </div>

          <div className="mt-6 rounded-[1.25rem] border border-white/10 bg-black/10 p-4">
            <div className="flex flex-wrap items-center justify-between gap-3">
              <div>
                <p className="text-xs uppercase tracking-[0.18em] text-amber-100/75">?„мһ¬ ?Ёкі„</p>
                <p className="mt-1 text-lg font-semibold">
                  {step === 'tutorial' ? '?ңнҶ лҰ¬м–ј' : step === 'marking' ? '?өм•Ҳ л§ҲнӮ№' : 'мұ„м җ кІ°кіј'}
                </p>
              </div>
              <div>
                <p className="text-xs uppercase tracking-[0.18em] text-amber-100/75">?Ём? ?ңк°„</p>
                <p className="mt-1 text-2xl font-semibold tabular-nums">{formatTime(remainingSeconds)}</p>
              </div>
            </div>
          </div>
        </section>

        <section className="grid gap-5">
          {step === 'tutorial' ? (
            <>
              <article className="rounded-[1.5rem] border border-stone-200 bg-[#fffdf8] p-6 shadow-[0_12px_40px_rgba(65,44,17,0.08)]">
                <p className="text-sm font-semibold uppercase tracking-[0.16em] text-[#955f21]">?‘мӢң ?ҲлӮҙ</p>
                <div className="mt-5 grid gap-4">
                  <div className="rounded-2xl bg-[#f3eadb] p-5">
                    <p className="text-lg font-semibold">1. мў…мқҙ???Җ?ҙн•ҳкі??ұм—җ???өл§Ң л§ҲнӮ№</p>
                    <p className="mt-2 text-sm leading-6 text-stone-700">?Өм ң ?ңн—ҳмІҳлҹј л¬ём ң??м§Җл©ҙмңјлЎ??Җкі? к°қк??қкіј мЈјк????•лӢөл§?OMR ?”л©ҙ???…л Ҙ?ҳлҠ” ?җлҰ„?…лӢҲ??</p>
                  </div>
                  <div className="rounded-2xl bg-[#f3eadb] p-5">
                    <p className="text-lg font-semibold">2. к°қк??қм? ?°м№ҳ, мЈјк??қм? ?«мһҗ ?…л Ҙ</p>
                    <p className="mt-2 text-sm leading-6 text-stone-700">к°қк??қм? 1к°ңл§Ң ? нғқ?ҳл©° ?ӨмӢң ?„лҘҙл©??ҙм ң?©лӢҲ?? мЈјк??қм? ?«мһҗл§??…л Ҙ?©лӢҲ??</p>
                  </div>
                  <div className="rounded-2xl bg-[#f3eadb] p-5">
                    <p className="text-lg font-semibold">3. ?ңм¶ң мҰүмӢң мұ„м җ кІ°кіј ?•мқё</p>
                    <p className="mt-2 text-sm leading-6 text-stone-700">?ңм¶ң ??мҙқм җ, ?•мҳӨ??к°ңмҲҳ, л¬ён•ӯлі?кІ°кіјлҘ?л°”лЎң ?•мқё?????ҲмҠө?ҲлӢӨ.</p>
                  </div>
                </div>
              </article>

              <article className="rounded-[1.5rem] border border-stone-200 bg-white p-6">
                <p className="text-sm font-semibold uppercase tracking-[0.16em] text-stone-500">?ңн—ҳ кө¬м„ұ</p>
                <div className="mt-4 grid gap-3 text-sm leading-6 text-stone-700 sm:grid-cols-2">
                  <div className="rounded-xl border border-stone-200 px-4 py-3">к°қк???14л¬ён•ӯ</div>
                  <div className="rounded-xl border border-stone-200 px-4 py-3">мЈјк???11л¬ён•ӯ</div>
                  <div className="rounded-xl border border-stone-200 px-4 py-3">мҙ?{data?.totalQuestions ?? 25}л¬ён•ӯ</div>
                  <div className="rounded-xl border border-stone-200 px-4 py-3">?ңн—ҳ ?ңк°„ {EXAM_DURATION_MINUTES}л¶?/div>
                </div>
                <button
                  type="button"
                  onClick={handleStartExam}
                  className="mt-6 inline-flex w-full items-center justify-center rounded-2xl bg-[#1f4a3d] px-5 py-4 text-base font-semibold text-white transition hover:bg-[#17382f]"
                >
                  ?‘мӢң ?ңмһ‘
                </button>
              </article>
            </>
          ) : null}

          {step === 'marking' ? (
            <>
              <article className="rounded-[1.5rem] border border-stone-200 bg-white p-6 shadow-[0_12px_40px_rgba(65,44,17,0.08)]">
                <div className="flex flex-wrap items-center justify-between gap-3">
                  <div>
                    <p className="text-sm font-semibold uppercase tracking-[0.16em] text-stone-500">?‘мӢң???•ліҙ</p>
                    <p className="mt-1 text-sm text-stone-600">?ңм¶ң ???„мҲҳ ?•ліҙ?…лӢҲ??</p>
                  </div>
                  <div className="rounded-full bg-stone-100 px-4 py-2 text-sm font-medium text-stone-700">
                    ?„мһ¬ {totalAnsweredCount} / {data?.totalQuestions ?? 25} л¬ён•ӯ ?…л Ҙ
                  </div>
                </div>

                <div className="mt-5 grid gap-4 sm:grid-cols-2">
                  <label className="grid gap-2 text-sm font-medium text-stone-700">
                    ?ҙлҰ„
                    <input
                      value={studentForm.name}
                      onChange={(event) => handleStudentFieldChange('name', event.target.value)}
                      className="h-12 rounded-xl border border-stone-300 px-4 text-base outline-none transition focus:border-[#1f4a3d]"
                      placeholder="?Қкёё??
                    />
                  </label>
                  <label className="grid gap-2 text-sm font-medium text-stone-700">
                    ?ҷкөҗлӘ?                    <input
                      value={studentForm.school}
                      onChange={(event) => handleStudentFieldChange('school', event.target.value)}
                      className="h-12 rounded-xl border border-stone-300 px-4 text-base outline-none transition focus:border-[#1f4a3d]"
                      placeholder="лІ мқҙ?Өкі "
                    />
                  </label>
                  <label className="grid gap-2 text-sm font-medium text-stone-700">
                    ?ҷл…„
                    <input
                      inputMode="numeric"
                      value={studentForm.grade}
                      onChange={(event) => handleStudentFieldChange('grade', event.target.value)}
                      className="h-12 rounded-xl border border-stone-300 px-4 text-base outline-none transition focus:border-[#1f4a3d]"
                      placeholder="1"
                    />
                  </label>
                  <label className="grid gap-2 text-sm font-medium text-stone-700">
                    ?ҷмғқ лІҲнҳё
                    <input
                      inputMode="numeric"
                      value={studentForm.studentNumber}
                      onChange={(event) => handleStudentFieldChange('studentNumber', event.target.value)}
                      className="h-12 rounded-xl border border-stone-300 px-4 text-base outline-none transition focus:border-[#1f4a3d]"
                      placeholder="12"
                    />
                  </label>
                  <label className="grid gap-2 text-sm font-medium text-stone-700 sm:col-span-2">
                    мўҢм„қ лІҲнҳё
                    <input
                      inputMode="numeric"
                      value={studentForm.seatNumber}
                      onChange={(event) => handleStudentFieldChange('seatNumber', event.target.value)}
                      className="h-12 rounded-xl border border-stone-300 px-4 text-base outline-none transition focus:border-[#1f4a3d]"
                      placeholder="3"
                    />
                  </label>
                </div>
