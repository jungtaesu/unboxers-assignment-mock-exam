              <article className="rounded-[1.5rem] border border-stone-200 bg-[#fffdf8] p-6">
                <div className="flex items-center justify-between gap-3">
                  <div>
                    <p className="text-sm font-semibold uppercase tracking-[0.16em] text-[#955f21]">к°қк???OMR</p>
                    <p className="mt-1 text-sm text-stone-600">лІҲнҳёлі„лЎң 1к°ңл§Ң ? нғқ?©лӢҲ??</p>
                  </div>
                  <div className="rounded-full bg-[#f3eadb] px-4 py-2 text-sm font-medium text-stone-700">
                    {objectiveAnsweredCount} / 14 ?…л Ҙ
                  </div>
                </div>
                <div className="mt-5 grid gap-4">
                  {OBJECTIVE_QUESTIONS.map((questionNumber) => (
                    <div key={questionNumber} className="rounded-2xl border border-stone-200 bg-white p-4">
                      <div className="flex flex-wrap items-center gap-3">
                        <div className="flex h-12 w-12 items-center justify-center rounded-2xl bg-[#1f4a3d] text-lg font-semibold text-white">
                          {questionNumber}
                        </div>
                        <div className="grid flex-1 grid-cols-5 gap-2">
                          {OBJECTIVE_CHOICES.map((choice) => {
                            const isSelected = objectiveAnswers[questionNumber] === choice

                            return (
                              <button
                                key={choice}
                                type="button"
                                onClick={() => handleObjectiveSelect(questionNumber, choice)}
                                className={[
                                  'h-14 rounded-2xl border text-lg font-semibold transition',
                                  isSelected
                                    ? 'border-[#1f4a3d] bg-[#1f4a3d] text-white shadow-[0_10px_30px_rgba(31,74,61,0.2)]'
                                    : 'border-stone-300 bg-stone-50 text-stone-700 hover:border-stone-400',
                                ].join(' ')}
                              >
                                {choice}
                              </button>
                            )
                          })}
                        </div>
                      </div>
                    </div>
                  ))}
                </div>
              </article>

              <article className="rounded-[1.5rem] border border-stone-200 bg-white p-6">
                <div className="flex items-center justify-between gap-3">
                  <div>
                    <p className="text-sm font-semibold uppercase tracking-[0.16em] text-stone-500">мЈјк????өм•Ҳ</p>
                    <p className="mt-1 text-sm text-stone-600">?«мһҗл§??…л Ҙ?©лӢҲ??</p>
                  </div>
                  <div className="rounded-full bg-stone-100 px-4 py-2 text-sm font-medium text-stone-700">
                    {subjectiveAnsweredCount} / 11 ?…л Ҙ
                  </div>
                </div>
                <div className="mt-5 grid gap-3 sm:grid-cols-2 xl:grid-cols-3">
                  {SUBJECTIVE_QUESTIONS.map((questionNumber) => (
                    <label key={questionNumber} className="rounded-2xl border border-stone-200 bg-[#fcfaf5] p-4 text-sm font-medium text-stone-700">
                      <span className="mb-2 block">мЈјк???{questionNumber}лІ?/span>
                      <input
                        inputMode="numeric"
                        value={subjectiveAnswers[questionNumber]}
                        onChange={(event) => {
                          const value = event.target.value.replace(/[^0-9-]/g, '')

                          setSubjectiveAnswers((current) => ({
                            ...current,
                            [questionNumber]: value,
                          }))
                        }}
                        className="h-12 w-full rounded-xl border border-stone-300 bg-white px-4 text-base outline-none transition focus:border-[#1f4a3d]"
                        placeholder="?«мһҗ ?…л Ҙ"
                      />
                    </label>
                  ))}
                </div>

                <div className="mt-6 space-y-3">
                  {validationMessage ? (
                    <div className="rounded-2xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-700">
                      {validationMessage}
                    </div>
                  ) : null}

                  {submitMutation.isError ? (
                    <div className="rounded-2xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-700">
                      {submitMutation.error instanceof Error
                        ? submitMutation.error.message
                        : '?ңм¶ң мӨ??ӨлҘҳк°Җ л°ңмғқ?ҲмҠө?ҲлӢӨ.'}
                    </div>
                  ) : null}

                  <div className="flex flex-col gap-3 sm:flex-row">
                    <button
                      type="button"
                      onClick={() => setStep('tutorial')}
                      className="inline-flex flex-1 items-center justify-center rounded-2xl border border-stone-300 bg-white px-5 py-4 text-base font-semibold text-stone-700 transition hover:bg-stone-50"
                    >
                      ?ҲлӮҙлЎ??Ңм•„к°Җкё?                    </button>
                    <button
                      type="button"
                      onClick={handleSubmit}
                      disabled={submitMutation.isPending}
                      className="inline-flex flex-1 items-center justify-center rounded-2xl bg-[#1f4a3d] px-5 py-4 text-base font-semibold text-white transition hover:bg-[#17382f] disabled:cursor-not-allowed disabled:opacity-60"
                    >
                      {submitMutation.isPending ? '?ңм¶ң мӨ?..' : '?өм•Ҳ ?ңм¶ң'}
                    </button>
                  </div>
                </div>
              </article>
            </>
          ) : null}

          {step === 'result' && result ? (
            <>
              <article className="rounded-[1.5rem] border border-stone-200 bg-white p-6 shadow-[0_12px_40px_rgba(65,44,17,0.08)]">
                <p className="text-sm font-semibold uppercase tracking-[0.16em] text-stone-500">мұ„м җ ?”м•Ҫ</p>
                <div className="mt-5 grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
                  <div className="rounded-2xl bg-[#f3eadb] p-5">
                    <p className="text-sm text-stone-500">мҙқм җ</p>
                    <p className="mt-2 text-3xl font-semibold text-stone-900">{result.score}??/p>
                  </div>
                  <div className="rounded-2xl bg-[#edf7f0] p-5">
                    <p className="text-sm text-stone-500">?•лӢө</p>
                    <p className="mt-2 text-3xl font-semibold text-emerald-700">{result.correctCount}к°?/p>
                  </div>
                  <div className="rounded-2xl bg-[#fff0ef] p-5">
                    <p className="text-sm text-stone-500">?ӨлӢө</p>
                    <p className="mt-2 text-3xl font-semibold text-rose-700">{result.wrongCount}к°?/p>
                  </div>
                  <div className="rounded-2xl bg-stone-100 p-5">
                    <p className="text-sm text-stone-500">лҜёмқ‘??/p>
                    <p className="mt-2 text-3xl font-semibold text-stone-700">{result.unansweredCount}к°?/p>
                  </div>
                </div>
              </article>

              <article className="rounded-[1.5rem] border border-stone-200 bg-[#fffdf8] p-6">
                <p className="text-sm font-semibold uppercase tracking-[0.16em] text-[#955f21]">? нҳ•лі?кІ°кіј</p>
                <div className="mt-5 grid gap-4 sm:grid-cols-2">
                  <div className="rounded-2xl border border-stone-200 bg-white p-5">
                    <p className="text-lg font-semibold text-stone-900">к°қк???/p>
                    <div className="mt-4 grid grid-cols-2 gap-3 text-sm text-stone-700">
                      <div className="rounded-xl bg-stone-100 px-4 py-3">?•лӢө {resultCount(result.results, 'objective', 'correct')}</div>
                      <div className="rounded-xl bg-stone-100 px-4 py-3">?ӨлӢө {resultCount(result.results, 'objective', 'wrong')}</div>
                      <div className="rounded-xl bg-stone-100 px-4 py-3">лҜёмқ‘??{resultCount(result.results, 'objective', 'unanswered')}</div>
                      <div className="rounded-xl bg-stone-100 px-4 py-3">мӨ‘ліө {resultCount(result.results, 'objective', 'duplicated')}</div>
                    </div>
                  </div>
                  <div className="rounded-2xl border border-stone-200 bg-white p-5">
                    <p className="text-lg font-semibold text-stone-900">мЈјк???/p>
                    <div className="mt-4 grid grid-cols-2 gap-3 text-sm text-stone-700">
                      <div className="rounded-xl bg-stone-100 px-4 py-3">?•лӢө {resultCount(result.results, 'subjective', 'correct')}</div>
                      <div className="rounded-xl bg-stone-100 px-4 py-3">?ӨлӢө {resultCount(result.results, 'subjective', 'wrong')}</div>
                      <div className="rounded-xl bg-stone-100 px-4 py-3">лҜёмқ‘??{resultCount(result.results, 'subjective', 'unanswered')}</div>
                      <div className="rounded-xl bg-stone-100 px-4 py-3">мӨ‘ліө {resultCount(result.results, 'subjective', 'duplicated')}</div>
                    </div>
                  </div>
                </div>
              </article>

              <article className="rounded-[1.5rem] border border-stone-200 bg-white p-6">
                <div className="flex flex-wrap items-center justify-between gap-3">
                  <div>
                    <p className="text-sm font-semibold uppercase tracking-[0.16em] text-stone-500">л¬ён•ӯлі?кІ°кіј</p>
                    <p className="mt-1 text-sm text-stone-600">?ңлІ„ мұ„м җ кІ°кіјлҘ?к·ёл?лЎ??ңмӢң?©лӢҲ??</p>
                  </div>
                  <button
                    type="button"
                    onClick={() => {
                      setStep('tutorial')
                      setRemainingSeconds(EXAM_DURATION_MINUTES * 60)
                      submitMutation.reset()
                    }}
                    className="inline-flex items-center justify-center rounded-2xl bg-[#1f4a3d] px-5 py-3 text-sm font-semibold text-white transition hover:bg-[#17382f]"
                  >
                    ?ӨмӢң ?‘мӢң?ҳкё°
                  </button>
                </div>

                <div className="mt-5 grid gap-3 lg:grid-cols-2">
                  {result.results.map((entry) => (
                    <div
                      key={`${entry.answerType}-${entry.number}`}
                      className="flex items-center justify-between rounded-2xl border border-stone-200 px-4 py-3"
                    >
                      <div>
                        <p className="text-sm font-semibold text-stone-900">
                          {entry.answerType === 'objective' ? 'к°қк??? : 'мЈјк???} {entry.number}лІ?                        </p>
                        <p className="mt-1 text-xs uppercase tracking-[0.14em] text-stone-500">{entry.answerType}</p>
                      </div>
                      <span className={`rounded-full border px-3 py-1 text-sm font-semibold ${resultToneMap[entry.result]}`}>
                        {resultLabelMap[entry.result]}
                      </span>
                    </div>
                  ))}
                </div>
              </article>
            </>
          ) : null}
        </section>
      </div>
    </main>
  )
}

export default App
