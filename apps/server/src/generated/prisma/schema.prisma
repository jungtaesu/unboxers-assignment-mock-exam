generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum AnswerType {
  objective
  subjective
}

model Exam {
  id             String     @id @default(cuid())
  title          String
  description    String?
  supervisorName String
  questions      Question[]
}

model Question {
  id            String     @id @default(cuid())
  examId        String
  answerType    AnswerType
  number        Int
  correctAnswer Int
  score         Float
  exam          Exam       @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@unique([examId, answerType, number])
}
